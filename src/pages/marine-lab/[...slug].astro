---
import { getCollection, render } from 'astro:content';
import MarineLabLayout from '../../layouts/MarineLabLayout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('marine-lab', ({ data }) => data.public);
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article, allArticles: articles },
  }));
}

const { article, allArticles } = Astro.props;
const { Content } = await render(article);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const navBase = `${base}/marine-lab`;
const navArticles = allArticles.map((a) => ({ id: a.id, title: a.data.title }));
---

<MarineLabLayout
  title={article.data.title}
  description={article.data.description}
  date={article.data.date}
  tags={article.data.tags}
  navArticles={navArticles}
  navBase={navBase}
  currentId={article.id}
>
  <Content />
</MarineLabLayout>

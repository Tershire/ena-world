---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavTree from '../../components/NavTree.astro';

const raw = (await getCollection('marine-lab'))
  .filter((a) => a.data.public)
  .sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0));

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const navBase = `${base}/marine-lab`;
const navArticles = raw.map((a) => ({ id: a.id, title: a.data.title }));
---

<BaseLayout title="Marine Lab">
  <div class="index-layout">
    {navArticles.length > 0 && (
      <aside class="index-nav">
        <div class="nav-sticky">
          <NavTree articles={navArticles} base={navBase} accent="var(--color-sky)" label="Marine Lab" />
        </div>
      </aside>
    )}

    <main class="index-main">
      <header class="station-header">
        <p class="station-label">Marine Research Station</p>
        <h1>Marine Lab</h1>
        <p class="station-desc">Underwater navigation · acoustic sensing · oceanic SLAM</p>
      </header>
    </main>
  </div>
</BaseLayout>

<style>
  .index-layout {
    display: flex;
    align-items: stretch;
    min-height: calc(100vh - 52px);
  }

  .index-nav { display: none; }

  @media (min-width: 1060px) {
    .index-nav {
      display: block;
      width: 280px;
      flex-shrink: 0;
      align-self: stretch;
      background: var(--bg-panel);
    }
  }

  .nav-sticky {
    position: sticky;
    top: 52px;
    max-height: calc(100vh - 52px);
    overflow-y: auto;
    padding: 1.25rem;
  }

  .index-main {
    flex: 1;
    min-width: 0;
    padding: 4rem 2rem;
  }

  .station-header {
    display: inline-block;
    background: rgba(255, 255, 255, 0.55);
    padding: 1.25rem 2rem 1.25rem;
    border-radius: 4px;
    margin-bottom: 2.5rem;
  }

  :global([data-theme="dark"]) .station-header {
    background: rgba(20, 17, 13, 0.55);
  }

  .station-header::after {
    content: '';
    display: block;
    height: 1px;
    background: var(--color-sepia);
    margin-top: 0.9rem;
  }

  .station-label {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-ink-faded);
    margin-bottom: 0.5rem;
  }

  .station-header h1 { font-size: 2.5rem; margin-bottom: 0.4rem; }

  .station-desc { color: var(--color-ink-faded); font-style: italic; }
</style>

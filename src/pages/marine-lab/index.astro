---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleGrid from '../../components/ArticleGrid';
import type { ArticleItem } from '../../components/ArticleGrid';

const raw = (await getCollection('marine-lab'))
  .filter((a) => !a.data.draft)
  .sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0));

const base = import.meta.env.BASE_URL;

const articles: ArticleItem[] = raw.map((a) => ({
  id:          a.id,
  title:       a.data.title,
  description: a.data.description,
  date:        a.data.date?.toISOString(),
  tags:        a.data.tags ?? [],
  href:        `${base}marine-lab/${a.id}`,
}));
---

<BaseLayout title="Marine Lab">
  <main class="index-wrap">
    <header class="station-header">
      <p class="station-label">Marine Research Station</p>
      <h1>Marine Lab</h1>
      <p class="station-desc">Underwater navigation · acoustic sensing · oceanic SLAM</p>
    </header>

    <ArticleGrid
      client:load
      articles={articles}
      accentVar="--color-sky"
      emptyMsg="No articles yet. The depths await."
    />
  </main>
</BaseLayout>

<style>
  .index-wrap {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .station-header {
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-sepia);
    padding-bottom: 1.75rem;
  }

  .station-label {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-ink-faded);
    margin-bottom: 0.5rem;
  }

  .station-header h1 { font-size: 2.5rem; margin-bottom: 0.4rem; }

  .station-desc { color: var(--color-ink-faded); font-style: italic; }
</style>

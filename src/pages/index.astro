---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlanetGlobe from '../components/PlanetGlobe';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home">
  <main class="home">
    <section class="planet-stage" id="planet-stage">
      <!-- Three.js planet — rendered client-side only -->
      <PlanetGlobe client:only="react" base={base} />

    </section>

  </main>
</BaseLayout>

<style>
  /* ── Hero / planet stage ─────────────────────────── */
  .planet-stage {
    position: relative;
    height: 100svh;
    overflow: hidden;
    background: radial-gradient(ellipse at 50% 60%, #1a2a3a 0%, #060e1a 100%);
  }

</style>

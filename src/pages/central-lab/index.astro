---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavTree from '../../components/NavTree.astro';

const raw = (await getCollection('central-lab'))
  .filter((a) => a.data.public)
  .sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0));

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const navBase = `${base}/central-lab`;
const navArticles = raw.map((a) => ({ id: a.id, title: a.data.title }));

const bgImage = `${base}/images/labs/central_lab_interior_day.webp`;
---

<BaseLayout title="Central Lab">
  <div class="index-layout" style={`background-image: url('${bgImage}')`}>
    {navArticles.length > 0 && (
      <aside class="index-nav">
        <div class="nav-sticky">
          <NavTree articles={navArticles} base={navBase} label="Central Lab" />
        </div>
      </aside>
    )}

    <main class="index-main">
      <header class="station-header">
        <p class="station-label">Central Research Station</p>
        <h1>Central Lab</h1>
        <p class="station-desc">Navigation, SLAM, and estimation theory — the main archive.</p>
      </header>
    </main>
  </div>
</BaseLayout>

<style>
  .index-layout {
    display: flex;
    align-items: stretch;
    min-height: calc(100vh - 52px);
    background-size: cover;
    background-position: center;
    flex: 1;
  }

  .index-nav { display: none; }

  @media (min-width: 1060px) {
    .index-nav {
      display: block;
      width: 280px;
      flex-shrink: 0;
      align-self: stretch;
      background: var(--bg-panel);
    }
  }

  .nav-sticky {
    position: sticky;
    top: 52px;
    max-height: calc(100vh - 52px);
    overflow-y: auto;
    padding: 1.25rem;
  }

  .index-main {
    flex: 1;
    min-width: 0;
    padding: 4rem 2rem;
  }

  .station-header {
    display: inline-block;
    background: rgba(255, 255, 255, 0.55);
    padding: 1.25rem 2rem 1.25rem;
    border-radius: 4px;
    margin-bottom: 2.5rem;
  }

  :global([data-theme="dark"]) .station-header {
    background: rgba(20, 17, 13, 0.55);
  }

  .station-header::after {
    content: '';
    display: block;
    height: 1px;
    background: var(--color-sepia);
    margin-top: 0.9rem;
  }

  .station-label {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-ink-faded);
    margin-bottom: 0.5rem;
  }

  .station-header h1 { font-size: 2.5rem; margin-bottom: 0.4rem; }

  .station-desc { color: var(--color-ink-faded); font-style: italic; }
</style>

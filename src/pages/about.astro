---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <div class="about-page">
    <div class="about-content">
      <header class="about-header">
        <p class="about-label">About</p>
        <h1>ENA World</h1>
        <p class="about-desc">
          A personal atlas of navigation and SLAM — field notes from an ongoing expedition
          into state estimation, sensor fusion, and probabilistic robotics.
          Each lab is a research station in a fictional world; each article, a charted territory.
        </p>
      </header>

      <a href="https://tershire.github.io/" class="portal" target="_blank" rel="noopener noreferrer">
          <div class="portal-inner">
            <svg class="portal-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
            <div class="portal-text">
              <span class="portal-label">Tershire</span>
              <span class="portal-url">tershire.github.io</span>
            </div>
            <svg class="portal-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </div>
        </a>
    </div>
  </div>
</BaseLayout>

<style>
  .about-page {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5rem 2rem;
    min-height: calc(100vh - 52px);
  }

  .about-content {
    max-width: 560px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .about-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .about-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-ink-faded);
    font-family: var(--font-display);
  }

  .about-header h1 {
    font-size: 2.5rem;
    margin: 0;
  }

  .about-desc {
    color: var(--color-ink-faded);
    font-size: 1rem;
    line-height: 1.75;
    margin: 0;
  }

  /* ── Rainbow border ───────────────────────────────── */
  @property --rainbow-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  @keyframes rainbow-spin {
    to { --rainbow-angle: 360deg; }
  }

  @keyframes portal-glow {
    0%   { box-shadow: 0 0 10px 3px rgba(255, 120, 120, 0.5), 0 6px 20px rgba(0,0,0,0.12); }
    14%  { box-shadow: 0 0 10px 3px rgba(255, 180,  50, 0.5), 0 6px 20px rgba(0,0,0,0.12); }
    28%  { box-shadow: 0 0 10px 3px rgba(100, 220, 100, 0.5), 0 6px 20px rgba(0,0,0,0.12); }
    42%  { box-shadow: 0 0 10px 3px rgba( 50, 160, 255, 0.5), 0 6px 20px rgba(0,0,0,0.12); }
    57%  { box-shadow: 0 0 10px 3px rgba(160,  50, 255, 0.5), 0 6px 20px rgba(0,0,0,0.12); }
    71%  { box-shadow: 0 0 10px 3px rgba(255,  50, 200, 0.5), 0 6px 20px rgba(0,0,0,0.12); }
    100% { box-shadow: 0 0 10px 3px rgba(255, 120, 120, 0.5), 0 6px 20px rgba(0,0,0,0.12); }
  }

  /* ── Portal card ──────────────────────────────────── */
  /*
   * background-clip trick:
   *   padding-box layer (top)   = solid fill, covers the interior
   *   border-box layer (bottom) = conic-gradient, peeks through only in border ring
   * Default: solid sepia border COVERS the gradient underneath.
   * Hover:   border-color → transparent, revealing the rotating rainbow.
   */
  .portal {
    display: block;
    text-decoration: none;
    border: 2px solid var(--color-sepia);
    border-radius: 8px;
    padding: calc(1.5rem - 2px) calc(1.75rem - 2px);
    background:
      linear-gradient(var(--color-parchment), var(--color-parchment)) padding-box,
      conic-gradient(
        from var(--rainbow-angle),
        #ff4d4d, #ff9900, #ffe033, #44d444, #4499ff, #9944ff, #ff4d4d
      ) border-box;
    animation: rainbow-spin 2.5s linear infinite paused;
    transition: border-color 0.1s, transform 0.2s;
  }

  .portal:hover {
    border-color: transparent;
    transform: translateY(-2px);
    animation: rainbow-spin 2.5s linear infinite, portal-glow 2.5s linear infinite;
  }

  .portal-inner {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .portal-icon {
    width: 2.25rem;
    height: 2.25rem;
    flex-shrink: 0;
    color: var(--color-rust);
    opacity: 0.85;
  }

  .portal-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .portal-label {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--color-ink);
    font-weight: 600;
  }

  .portal-url {
    font-size: 0.8rem;
    color: var(--color-ink-faded);
    font-style: italic;
  }

  .portal-arrow {
    width: 1.1rem;
    height: 1.1rem;
    color: var(--color-rust);
    flex-shrink: 0;
    opacity: 0.7;
    transition: opacity 0.15s, transform 0.2s;
  }

  .portal:hover .portal-arrow {
    opacity: 1;
    transform: translateX(3px);
  }
</style>

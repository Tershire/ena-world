---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import ClientRouter from 'astro/components/ClientRouter.astro';

interface Props {
  title: string;
  description?: string;
  noFooter?: boolean;
}

const { title, description = 'ENA World — Navigation & SLAM explorer', noFooter = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function stripMarkdown(md: string) {
  return md
    .replace(/^---[\s\S]*?---\n/m, '')   // frontmatter
    .replace(/\$\$[\s\S]*?\$\$/g, ' ')   // display math
    .replace(/\$[^$\n]+\$/g, ' ')        // inline math
    .replace(/```[\s\S]*?```/g, ' ')     // code blocks
    .replace(/`[^`]+`/g, ' ')           // inline code
    .replace(/!?\[([^\]]*)\]\([^)]*\)/g, '$1') // links/images → keep label
    .replace(/#{1,6}\s/g, '')            // headings
    .replace(/[*_~>|\\]/g, ' ')         // emphasis, blockquote, table
    .replace(/\s+/g, ' ')
    .trim();
}

const searchIndex = [
  ...(await getCollection('central-lab')).filter(a => a.data.public).map(a => ({
    title: a.data.title,
    description: a.data.description ?? '',
    tags: a.data.tags ?? [],
    date: a.data.date?.toISOString() ?? '',
    body: stripMarkdown(a.body ?? ''),
    href: `${base}/central-lab/${a.id}`,
    lab: 'Central Lab',
    accent: 'var(--color-sepia)',
  })),
  ...(await getCollection('aerospace-lab')).filter(a => a.data.public).map(a => ({
    title: a.data.title,
    description: a.data.description ?? '',
    tags: a.data.tags ?? [],
    date: a.data.date?.toISOString() ?? '',
    body: stripMarkdown(a.body ?? ''),
    href: `${base}/aerospace-lab/${a.id}`,
    lab: 'Aerospace Lab',
    accent: 'var(--color-sky)',
  })),
  ...(await getCollection('marine-lab')).filter(a => a.data.public).map(a => ({
    title: a.data.title,
    description: a.data.description ?? '',
    tags: a.data.tags ?? [],
    date: a.data.date?.toISOString() ?? '',
    body: stripMarkdown(a.body ?? ''),
    href: `${base}/marine-lab/${a.id}`,
    lab: 'Marine Lab',
    accent: 'var(--color-sky)',
  })),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} · ENA World</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Abel&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
    <ClientRouter />
    <!-- Theme init: runs before paint to prevent flash -->
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem('ena-theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.dataset.theme = saved ?? (prefersDark ? 'dark' : 'light');
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <nav class="site-nav">
      <a href={base} class="nav-home">ENA World</a>
      <div class="nav-right">
        <div class="nav-links">
          <a href={`${base}/central-lab`}>Central Lab</a>
          <a href={`${base}/marine-lab`}>Marine Lab</a>
          <a href={`${base}/aerospace-lab`}>Aerospace Lab</a>
        </div>
        <button id="search-btn" aria-label="Search articles" title="Search (/)">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
        <button id="theme-toggle" aria-label="Toggle light / dark mode" title="Toggle theme">
        <!-- Moon: shown in light mode -->
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <!-- Sun: shown in dark mode -->
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        </button>
      </div>
    </nav>

    <slot />

    <!-- Search modal -->
    <div id="search-overlay" aria-hidden="true" role="dialog" aria-label="Search articles">
      <div id="search-modal">
        <div id="search-box">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;color:var(--color-ink-faded)">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <input id="search-input" type="search" placeholder="Search articles…" autocomplete="off" spellcheck="false" />
          <button id="search-close" aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
        <ul id="search-results" role="listbox"></ul>
        <p id="search-hint">Type to search all labs</p>
      </div>
    </div>

    {!noFooter && (
      <footer class="site-footer">
        <p>Charted by tershire · <a href="https://github.com/tershire/ena-world">source</a></p>
      </footer>
    )}

    <script define:vars={{ searchIndex }}>
      window.__searchIndex = searchIndex;
    </script>

    <script>
      let activeIdx = -1;

      function g(id: string) { return document.getElementById(id); }

      // ── Theme: sync icon state (called on page-load and after toggle) ──
      function syncThemeIcon() {
        const dark = document.documentElement.dataset.theme === 'dark';
        const moon = g('icon-moon') as HTMLElement | null;
        const sun  = g('icon-sun')  as HTMLElement | null;
        if (moon) moon.style.display = dark ? 'none' : 'block';
        if (sun)  sun.style.display  = dark ? 'block' : 'none';
      }

      // Delegate from document — never needs re-binding after navigation
      document.addEventListener('click', (e) => {
        if (!(e.target as Element).closest('#theme-toggle')) return;
        const dark = document.documentElement.dataset.theme === 'dark';
        document.documentElement.dataset.theme = dark ? 'light' : 'dark';
        localStorage.setItem('ena-theme', document.documentElement.dataset.theme);
        syncThemeIcon();
      });

      // ── Search helpers ─────────────────────────────────────────────
      function searchOpen() {
        const overlay = g('search-overlay');
        const input   = g('search-input') as HTMLInputElement;
        const results = g('search-results')!;
        const hint    = g('search-hint') as HTMLElement;
        const box     = g('search-box') as HTMLElement;
        if (!overlay || !input) return;
        overlay.setAttribute('aria-hidden', 'false');
        overlay.classList.add('open');
        input.value = '';
        activeIdx = -1;
        results.innerHTML = '';
        hint.style.display = 'none';
        box.style.borderBottom = 'none';
        requestAnimationFrame(() => input.focus());
      }

      function searchClose() {
        const overlay = g('search-overlay');
        if (!overlay) return;
        overlay.setAttribute('aria-hidden', 'true');
        overlay.classList.remove('open');
      }

      // Global keyboard shortcuts — registered once
      document.addEventListener('keydown', (e) => {
        const overlay = g('search-overlay');
        const tag = (document.activeElement as HTMLElement)?.tagName ?? '';
        if (e.key === '/' && !['INPUT','TEXTAREA'].includes(tag)) { e.preventDefault(); searchOpen(); }
        if (e.key === 'k' && (e.ctrlKey || e.metaKey)) { e.preventDefault(); searchOpen(); }
        if (e.key === 'Escape' && overlay?.classList.contains('open')) searchClose();
      });

      // Re-sync icons + re-bind search elements after each navigation swap
      document.addEventListener('astro:page-load', () => {
        syncThemeIcon();

        const si        = (window as any).__searchIndex || [];
        const overlay   = g('search-overlay')!;
        const input     = g('search-input') as HTMLInputElement;
        const results   = g('search-results')!;
        const hint      = g('search-hint') as HTMLElement;
        const searchBox = g('search-box') as HTMLElement;

        function fmtDate(iso: string) {
          if (!iso) return '';
          return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
        }

        function applyHover(link: HTMLElement, ac: string, on: boolean) {
          link.style.background  = on ? `color-mix(in srgb,${ac} 14%,transparent)` : `color-mix(in srgb,${ac} 7%,transparent)`;
          link.style.borderColor = on ? `color-mix(in srgb,${ac} 52%,transparent)` : `color-mix(in srgb,${ac} 28%,transparent)`;
        }

        function makeCard(a: any) {
          const ac = a.accent;
          const li = document.createElement('li');
          li.dataset.accent = ac;
          const link = document.createElement('a');
          link.href = a.href;
          link.style.cssText = `
            display:grid;grid-template-columns:1fr auto;grid-template-rows:auto auto;
            gap:0.25rem 1rem;padding:0.9rem 1.1rem;
            background:color-mix(in srgb,${ac} 7%,transparent);
            border:1px solid color-mix(in srgb,${ac} 28%,transparent);
            border-radius:4px;text-decoration:none;
            transition:background 0.15s,border-color 0.15s;
          `;
          const title = document.createElement('span');
          title.textContent = a.title;
          title.style.cssText = `font-family:var(--font-display);font-size:1rem;color:var(--color-ink);grid-column:1;grid-row:1;line-height:1.3;`;
          const badge = document.createElement('span');
          badge.textContent = a.lab;
          badge.style.cssText = `font-size:0.62rem;padding:0.15em 0.55em;border-radius:999px;background:color-mix(in srgb,${ac} 18%,transparent);color:var(--color-ink-faded);white-space:nowrap;align-self:center;grid-column:2;grid-row:1;`;
          link.appendChild(title);
          link.appendChild(badge);
          if (a.description) {
            const desc = document.createElement('span');
            desc.textContent = a.description;
            desc.style.cssText = `font-size:0.82rem;color:var(--color-ink-faded);font-style:italic;grid-column:1/-1;grid-row:2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;`;
            link.appendChild(desc);
          }
          const dateStr = fmtDate(a.date);
          if (dateStr) {
            const time = document.createElement('time');
            time.textContent = dateStr;
            time.style.cssText = `font-size:0.7rem;color:var(--color-ink-faded);grid-column:1/-1;grid-row:${a.description ? 3 : 2};margin-top:0.1rem;`;
            link.appendChild(time);
          }
          link.addEventListener('mouseenter', () => { if (!li.classList.contains('active')) applyHover(link, ac, true); });
          link.addEventListener('mouseleave', () => { if (!li.classList.contains('active')) applyHover(link, ac, false); });
          li.appendChild(link);
          return li;
        }

        function render(query: string) {
          const q = query.toLowerCase().trim();
          activeIdx = -1;
          results.innerHTML = '';
          if (!q) { hint.style.display = 'none'; searchBox.style.borderBottom = 'none'; return; }
          const hits = si.filter((a: any) =>
            a.title.toLowerCase().includes(q) ||
            a.description.toLowerCase().includes(q) ||
            a.tags.some((t: string) => t.toLowerCase().includes(q)) ||
            a.body.toLowerCase().includes(q)
          );
          searchBox.style.borderBottom = '1px solid var(--color-sepia)';
          if (hits.length === 0) { hint.textContent = 'No results'; hint.style.display = 'block'; return; }
          hint.style.display = 'none';
          hits.forEach((a: any) => results.appendChild(makeCard(a)));
        }

        function setActive(idx: number) {
          const items = results.querySelectorAll('li');
          items.forEach((li, i) => {
            const link = li.querySelector('a') as HTMLElement;
            const on = i === idx;
            li.classList.toggle('active', on);
            if (link) applyHover(link, (li as HTMLElement).dataset.accent!, on);
          });
          activeIdx = idx;
          if (idx >= 0) (items[idx] as HTMLElement)?.scrollIntoView({ block: 'nearest' });
        }

        g('search-btn')?.addEventListener('click', searchOpen);
        g('search-close')?.addEventListener('click', searchClose);
        overlay?.addEventListener('click', (e) => { if (e.target === overlay) searchClose(); });
        input?.addEventListener('input', () => render(input.value));
        input?.addEventListener('keydown', (e) => {
          const items = results.querySelectorAll('li');
          if (e.key === 'ArrowDown') { e.preventDefault(); setActive(Math.min(activeIdx + 1, items.length - 1)); }
          if (e.key === 'ArrowUp')   { e.preventDefault(); setActive(Math.max(activeIdx - 1, -1)); }
          if (e.key === 'Enter' && activeIdx >= 0) {
            const link = items[activeIdx]?.querySelector('a') as HTMLAnchorElement;
            if (link) { searchClose(); window.location.href = link.href; }
          }
          if (e.key === 'Escape') searchClose();
        });
      });
    </script>
  </body>
</html>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 2rem;
    border-bottom: 1px solid var(--color-sepia);
    background: #ffffff;
    position: sticky;
    top: 0;
    z-index: 100;
    transition: background 0.25s ease;
  }

  [data-theme="dark"] .site-nav {
    background: #14110d;
  }

  .nav-home {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-ink);
    text-decoration: none;
    letter-spacing: 0.05em;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    color: var(--color-ink-faded);
    text-decoration: none;
    font-size: 0.875rem;
    letter-spacing: 0.03em;
    transition: color 0.15s;
  }

  .nav-links a:hover { color: var(--color-ink); }

  #search-btn,
  #theme-toggle {
    background: none;
    border: 1px solid var(--color-sepia);
    border-radius: 4px;
    padding: 0.3rem 0.45rem;
    cursor: pointer;
    color: var(--color-ink-faded);
    display: flex;
    align-items: center;
    transition: color 0.15s, border-color 0.15s;
  }
  #search-btn:hover,
  #theme-toggle:hover { color: var(--color-ink); border-color: var(--color-ink); }

  /* ── Search overlay ────────────────────────────────── */
  #search-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 500;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(3px);
    align-items: flex-start;
    justify-content: center;
    padding-top: 14vh;
  }
  #search-overlay.open { display: flex; }

  #search-modal {
    width: 100%;
    max-width: 580px;
    margin: 0 1rem;
    background: var(--color-parchment);
    border: 1px solid var(--color-sepia);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.25);
  }

  #search-box {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0 1rem;
    transition: border-bottom 0.1s;
  }

  #search-input {
    flex: 1;
    border: none;
    background: transparent;
    padding: 1rem 0;
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-ink);
    outline: none;
  }
  #search-input::placeholder { color: var(--color-ink-faded); }
  /* hide browser's native clear button */
  #search-input::-webkit-search-cancel-button { display: none; }

  #search-close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-ink-faded);
    padding: 0.25rem;
    display: flex;
    align-items: center;
    border-radius: 4px;
    flex-shrink: 0;
    transition: color 0.15s;
  }
  #search-close:hover { color: var(--color-ink); }

  #search-results {
    list-style: none;
    padding: 0.5rem;
    margin: 0;
    max-height: 420px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  #search-hint {
    margin: 0;
    padding: 0.9rem 1.25rem;
    font-size: 0.8rem;
    color: var(--color-ink-faded);
    font-style: italic;
    text-align: center;
  }

</style>

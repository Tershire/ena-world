---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'ENA World — Navigation & SLAM explorer' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} · ENA World</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body>
    <nav class="site-nav">
      <a href={base} class="nav-home">ENA World</a>
      <div class="nav-links">
        <a href={`${base}/central-lab`}>Central Lab</a>
        <a href={`${base}/marine-lab`}>Marine Lab</a>
        <a href={`${base}/aerospace-lab`}>Aerospace Lab</a>
      </div>
    </nav>

    <slot />

    <footer class="site-footer">
      <p>Charted by tershire · <a href="https://github.com/tershire/ena-world">source</a></p>
    </footer>
  </body>
</html>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
    border-bottom: 1px solid var(--color-sepia);
    background: rgba(245, 234, 214, 0.9);
    backdrop-filter: blur(4px);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-home {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-ink);
    text-decoration: none;
    letter-spacing: 0.05em;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    color: var(--color-ink-faded);
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 0.03em;
  }

  .nav-links a:hover {
    color: var(--color-ink);
  }

  .site-footer {
    margin-top: 6rem;
    padding: 2rem;
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-ink-faded);
    border-top: 1px solid var(--color-sepia);
  }
</style>

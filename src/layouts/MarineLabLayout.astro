---
import BaseLayout from './BaseLayout.astro';
import NavTree from '../components/NavTree.astro';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
  navArticles?: { id: string; title: string }[];
  navBase?: string;
  navLabel?: string;
  currentId?: string;
}

const { title, description, date, tags = [], navArticles, navBase, navLabel = 'Marine Lab', currentId } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const hasNav = navArticles && navArticles.length > 0 && navBase;
---

<BaseLayout title={title} description={description} noFooter={true}>
  <!-- Fixed ocean background -->
  <div id="marine-bg" aria-hidden="true">
    <img id="ocean-day"   src={`${base}/images/functional/ocean_profile(day).webp`}   alt="" />
    <img id="ocean-night" src={`${base}/images/functional/ocean_profile(night).webp`} alt="" />
  </div>

  <!-- Top reading progress bar -->
  <div id="reading-bar"></div>

  <!--
    Right depth ruler — three columns:
      [indicator readout] | [vertical line] | [zone labels (left-aligned)]
    Ruler top = surface (0 m), bottom = abyss (4000 m).
    Indicator moves DOWN as reading progress increases.
  -->
  <div id="depth-ruler" aria-hidden="true">
    <div id="ruler-readout">
      <div class="ruler-value">
        <span id="ruler-num">0</span><span class="ruler-unit"> m</span>
      </div>
      <div id="ruler-zone-name">Epipelagic</div>
    </div>
    <div id="ruler-line">
      <div id="ruler-pip"></div>
    </div>
    <div id="ruler-labels"></div>
  </div>

  <div class="lab-wrapper">
    {hasNav && (
      <aside id="nav-sidebar">
        <div class="nav-sticky">
          <NavTree articles={navArticles!} base={navBase!} currentId={currentId} accent="var(--color-sky)" label={navLabel} />
        </div>
      </aside>
    )}
    <div class="lab-content">
      <div class="article-page">
        <main>
          <article class="prose">
            <header class="article-header">
              <div class="station-badge">Marine Research Station</div>
              <h1>{title}</h1>
              {description && <p class="description">{description}</p>}
              <div class="meta">
                {date && (
                  <time datetime={date.toISOString()}>
                    {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                )}
                {tags.length > 0 && (
                  <ul class="tags">
                    {tags.map((tag) => <li class="tag">#{tag}</li>)}
                  </ul>
                )}
              </div>
            </header>
            <slot />
          </article>
        </main>

        <!-- Right sidebar: progress + TOC only -->
        <aside id="toc-sidebar">
          <div class="sidebar-card">
            <div class="progress-section">
              <div class="progress-header">
                <span class="sidebar-label">Progress</span>
                <span id="progress-pct">0%</span>
              </div>
              <div class="progress-track">
                <div id="progress-fill"></div>
              </div>
            </div>
            <div class="toc-section">
              <p class="sidebar-label">Contents</p>
              <ul id="toc-list"></ul>
            </div>
          </div>
        </aside>
      </div>
      <footer class="site-footer">
        <p>Charted by tershire · <a href="https://github.com/tershire/ena-world">source</a></p>
      </footer>
    </div>
  </div>
</BaseLayout>

<script>
  const imgDay    = document.getElementById('ocean-day')!   as HTMLImageElement;
  const imgNight  = document.getElementById('ocean-night')! as HTMLImageElement;
  const bar       = document.getElementById('reading-bar')!;
  const fill      = document.getElementById('progress-fill')!;
  const pctEl     = document.getElementById('progress-pct')!;
  const tocList   = document.getElementById('toc-list')!;
  const rulerLabels   = document.getElementById('ruler-labels')!;
  const rulerLine2    = document.getElementById('ruler-line')!;
  const rulerPip      = document.getElementById('ruler-pip')!;
  const rulerReadout  = document.getElementById('ruler-readout')!;
  const rulerNum      = document.getElementById('ruler-num')!;
  const rulerZoneName = document.getElementById('ruler-zone-name')!;

  // Day/night switching
  function syncImages() {
    const dark = document.documentElement.dataset.theme === 'dark';
    imgDay.style.opacity   = dark ? '0' : '1';
    imgNight.style.opacity = dark ? '1' : '0';
  }
  syncImages();
  new MutationObserver(syncImages).observe(document.documentElement, {
    attributes: true, attributeFilter: ['data-theme'],
  });

  // Depth config
  const MAX_DEPTH = 4000;
  const zones = [
    { name: 'Epipelagic',    minDepth: 0    },
    { name: 'Mesopelagic',   minDepth: 200  },
    { name: 'Bathypelagic',  minDepth: 1000 },
    { name: 'Abyssopelagic', minDepth: 4000 },
  ] as const;

  // Build zone labels (RIGHT column) + tick marks on the line
  zones.forEach((z) => {
    const pct = (z.minDepth / MAX_DEPTH) * 100;

    const label = document.createElement('div');
    label.style.cssText = `
      position: absolute;
      left: 6px;
      top: ${pct}%;
      transform: translateY(-50%);
      font-size: 0.55rem;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: #ffffff;
      white-space: nowrap;
      text-align: left;
    `;
    label.textContent = z.name;
    rulerLabels.appendChild(label);

    const tick = document.createElement('div');
    tick.style.cssText = `
      position: absolute;
      top: ${pct}%;
      right: -4px;
      width: 10px;
      height: 1px;
      background: rgba(255,255,255,0.55);
      transform: translateY(-50%);
    `;
    rulerLine2.appendChild(tick);
  });

  // Build TOC
  const headings = Array.from(
    document.querySelectorAll<HTMLHeadingElement>('.prose h2, .prose h3, .prose h4')
  );
  headings.forEach((h, i) => {
    if (!h.id) h.id = `s${i}`;
    const level = parseInt(h.tagName[1]);
    const li = document.createElement('li');
    const a  = document.createElement('a');
    a.href = `#${h.id}`;
    a.textContent = h.textContent;
    a.style.cssText = `
      display:block;
      padding:0.28rem 0.5rem;
      font-size:${level === 2 ? '0.8rem' : '0.74rem'};
      font-weight:${level === 2 ? '500' : '400'};
      color:var(--color-ink-faded);
      text-decoration:none;
      border-radius:0.3rem;
      margin-left:${(level - 2) * 0.75}rem;
      border-left:2px solid transparent;
      line-height:1.4;
      transition:color 0.1s, background 0.1s, border-color 0.1s;
    `;
    li.appendChild(a);
    tocList.appendChild(li);
  });

  // Scroll handler
  function onScroll() {
    const max      = document.documentElement.scrollHeight - window.innerHeight;
    const progress = max > 0 ? Math.min(window.scrollY / max, 1) : 0;

    // Ocean image: surface → abyss
    imgDay.style.objectPosition   = `center ${progress * 100}%`;
    imgNight.style.objectPosition = `center ${progress * 100}%`;

    // Progress bar
    const pct = progress * 100;
    bar.style.width   = `${pct}%`;
    fill.style.width  = `${pct}%`;
    pctEl.textContent = `${Math.round(pct)}%`;

    // Depth ruler: pip and readout move together
    const depth = Math.round(progress * MAX_DEPTH);
    rulerNum.textContent = depth.toLocaleString();
    rulerPip.style.top     = `${pct}%`;
    rulerReadout.style.top = `${pct}%`;

    let zone = zones[0];
    for (const z of zones) { if (depth >= z.minDepth) zone = z; }
    rulerZoneName.textContent = zone.name;
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Active heading
  const links = () => tocList.querySelectorAll<HTMLAnchorElement>('a');
  const obs = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        links().forEach((a) => {
          const active = a.getAttribute('href') === `#${e.target.id}`;
          a.style.color           = active ? 'var(--color-sky)' : 'var(--color-ink-faded)';
          a.style.fontWeight      = active ? '600' : (a.style.fontSize === '0.8rem' ? '500' : '400');
          a.style.borderLeftColor = active ? 'var(--color-sky)' : 'transparent';
          a.style.background      = active ? 'rgba(58,107,139,0.10)' : '';
        });
      }
    },
    { rootMargin: '-10% 0% -60% 0%' }
  );
  headings.forEach((h) => obs.observe(h));
</script>

<style>
  /* ── Ocean background ─────────────────────────────── */
  #marine-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
  }

  #marine-bg img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 0%;
    transition: opacity 0.3s ease;
  }

  /* ── Top progress bar (mobile only — sidebar shows progress on desktop) */
  #reading-bar {
    position: fixed;
    top: 0; left: 0;
    height: 3px;
    width: 0%;
    background: linear-gradient(90deg, #5bc8e8, #3a6b8b);
    z-index: 200;
    transition: width 0.1s linear;
  }

  @media (min-width: 1060px) {
    #reading-bar { display: none; }
  }

  /* ── Outer flex wrapper ───────────────────────────── */
  .lab-wrapper {
    display: flex;
    align-items: stretch;
    min-height: calc(100vh - 52px);
    flex: 1;
  }

  /* ── Left nav sidebar ─────────────────────────────── */
  #nav-sidebar { display: none; }

  @media (min-width: 1060px) {
    #nav-sidebar {
      display: block;
      width: 280px;
      flex-shrink: 0;
      align-self: stretch;
      background: var(--bg-panel);
    }
  }

  .nav-sticky {
    position: sticky;
    top: 52px;
    max-height: calc(100vh - 52px);
    overflow-y: auto;
    padding: 1.25rem;
  }

  .lab-content { flex: 1; min-width: 0; display: flex; flex-direction: column; }

  /* ── Right depth ruler ────────────────────────────── */
  #depth-ruler {
    position: fixed;
    right: 1rem;
    top: calc(52px + 3rem);
    bottom: 3rem;
    display: none;
    pointer-events: none;
    z-index: 20;
    align-items: stretch;
  }

  @media (min-width: 1380px) {
    #depth-ruler { display: flex; }
  }

  /* LEFT sub-column: readout (follows pip) */
  #ruler-readout {
    position: absolute;
    right: calc(88px + 2px + 8px);
    top: 0%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    text-align: right;
  }

  /* CENTER sub-column: vertical line */
  #ruler-line {
    width: 2px;
    flex-shrink: 0;
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.15) 0%,
      rgba(255, 255, 255, 0.5) 100%
    );
    border-radius: 999px;
    position: relative;
  }

  /* Moving pip */
  #ruler-pip {
    position: absolute;
    left: 50%;
    top: 0%;
    transform: translate(-50%, -50%);
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid white;
    background: transparent;
    box-shadow: 0 0 6px rgba(255, 255, 255, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #ruler-pip::after {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: white;
  }

  /* RIGHT sub-column: zone labels */
  #ruler-labels {
    width: 88px;
    height: 100%;
    position: relative;
    flex-shrink: 0;
  }

  .ruler-value { line-height: 1; }

  #ruler-num {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    color: #ffffff;
  }

  .ruler-unit {
    font-size: 0.7rem;
    color: #ffffff;
    font-family: var(--font-body);
  }

  #ruler-zone-name {
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #ffffff;
  }

  /* ── Page grid ────────────────────────────────────── */
  .article-page {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr;
    max-width: 1160px;
    margin: 0 auto;
    padding: 3rem 2rem;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1060px) {
    .article-page { grid-template-columns: 1fr 220px; }
  }

  /* ── Prose panel ─────────────────────────────────── */
  main { min-width: 0; }

  .prose {
    background: var(--bg-panel);
    padding: 2rem 2.5rem;
    border-radius: 6px;
    backdrop-filter: blur(3px);
    max-width: none;
  }

  /* ── TOC Sidebar ──────────────────────────────────────── */
  #toc-sidebar { display: none; }

  @media (min-width: 1060px) {
    #toc-sidebar {
      display: block;
      position: sticky;
      top: calc(52px + 2rem);
      max-height: calc(100vh - 52px - 4rem);
      overflow-y: auto;
    }
  }

  .sidebar-card {
    background: var(--bg-panel);
    border: 1px solid var(--color-sepia);
    border-radius: 4px;
    padding: 1.25rem;
    backdrop-filter: blur(4px);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── Progress section ─────────────────────────────── */
  .progress-section { display: flex; flex-direction: column; gap: 0.45rem; }

  .progress-header { display: flex; justify-content: space-between; align-items: center; }

  .sidebar-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-faded);
    font-family: var(--font-display);
  }

  #progress-pct { font-size: 0.75rem; font-weight: 600; color: var(--color-sky); }

  .progress-track {
    height: 4px;
    background: rgba(196, 154, 108, 0.2);
    border-radius: 999px;
    overflow: hidden;
  }

  #progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--color-sky), #5bc8e8);
    border-radius: 999px;
    transition: width 0.15s;
  }

  /* ── TOC ──────────────────────────────────────────── */
  .toc-section { display: flex; flex-direction: column; gap: 0.5rem; }

  #toc-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.05rem; }

  /* ── Article header ─────────────────────────────────── */
  .station-badge {
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-ink-faded);
    margin-bottom: 0.6rem;
  }

  .article-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-sepia);
  }

  .article-header h1 { font-size: 2.25rem; margin-bottom: 0.5rem; }

  .description { color: var(--color-ink-faded); font-size: 1.05rem; font-style: italic; margin-bottom: 1rem; }

  .meta { display: flex; align-items: center; gap: 1.5rem; font-size: 0.85rem; color: var(--color-ink-faded); }

  .tags { display: flex; gap: 0.5rem; list-style: none; padding: 0; margin: 0; }

  .tag { background: rgba(196, 154, 108, 0.2); padding: 0.15em 0.6em; border-radius: 999px; font-size: 0.8rem; color: var(--color-ink-faded); }
</style>

---
import BaseLayout from './BaseLayout.astro';
import NavTree from '../components/NavTree.astro';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
  navArticles?: { id: string; title: string }[];
  navBase?: string;
  navLabel?: string;
  currentId?: string;
}

const { title, description, date, tags = [], navArticles, navBase, navLabel, currentId } = Astro.props;
const hasNav = navArticles && navArticles.length > 0 && navBase;
---

<BaseLayout title={title} description={description} noFooter={true}>
  <!-- Top reading progress bar -->
  <div id="reading-bar"></div>

  <div class={`lab-wrapper${hasNav ? ' has-nav' : ''}`}>
    <!-- Left nav sidebar — sticks to page left edge -->
    {hasNav && (
      <aside id="nav-sidebar">
        <div class="nav-sticky">
          <NavTree articles={navArticles!} base={navBase!} currentId={currentId} label={navLabel} />
        </div>
      </aside>
    )}

    <!-- Article + TOC grid -->
    <div class="lab-content">
      <div class="article-page">
        <main>
          <article class="prose">
            <header class="article-header">
              <h1>{title}</h1>
              {description && <p class="description">{description}</p>}
              <div class="meta">
                {date && (
                  <time datetime={date.toISOString()}>
                    {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                )}
                {tags.length > 0 && (
                  <ul class="tags">
                    {tags.map((tag) => <li class="tag">#{tag}</li>)}
                  </ul>
                )}
              </div>
            </header>
            <slot />
          </article>
        </main>

        <!-- Right sidebar: progress + TOC -->
        <aside id="toc-sidebar">
          <div class="toc-card">
            <div class="progress-section">
              <div class="progress-header">
                <span class="sidebar-label">Progress</span>
                <span id="progress-pct">0%</span>
              </div>
              <div class="progress-track">
                <div id="progress-fill"></div>
              </div>
            </div>
            <div class="toc-section">
              <p class="sidebar-label">Contents</p>
              <ul id="toc-list"></ul>
            </div>
          </div>
        </aside>
      </div>
      <footer class="site-footer">
        <p>Charted by tershire · <a href="https://github.com/tershire/ena-world">source</a></p>
      </footer>
    </div>
  </div>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const ac = new AbortController();
    const { signal } = ac;
    document.addEventListener('astro:before-preparation', () => ac.abort(), { once: true });

    const bar     = document.getElementById('reading-bar')!;
    const fill    = document.getElementById('progress-fill')!;
    const pctEl   = document.getElementById('progress-pct')!;
    const tocList = document.getElementById('toc-list')!;

    const headings = Array.from(
      document.querySelectorAll<HTMLHeadingElement>('.prose h2, .prose h3, .prose h4')
    );
    headings.forEach((h, i) => {
      if (!h.id) h.id = `s${i}`;
      const level = parseInt(h.tagName[1]);

      if (h.textContent?.trim() === 'References') {
        const sep = document.createElement('li');
        sep.style.cssText = 'border-top:1px solid var(--color-sepia);margin:0.45rem 0 0.1rem;';
        tocList.appendChild(sep);
      }

      const li = document.createElement('li');
      const a  = document.createElement('a');
      a.href = `#${h.id}`;
      a.textContent = h.textContent;
      a.style.cssText = `
        display:block;
        padding:0.28rem 0.5rem;
        font-size:${level === 2 ? '0.8rem' : '0.74rem'};
        font-weight:${level === 2 ? '500' : '400'};
        color:var(--color-ink-faded);
        text-decoration:none;
        border-radius:0.3rem;
        margin-left:${(level - 2) * 0.75}rem;
        border-left:2px solid transparent;
        line-height:1.4;
        transition:color 0.1s, background 0.1s, border-color 0.1s;
      `;
      li.appendChild(a);
      tocList.appendChild(li);
    });

    function onScroll() {
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const pct = max > 0 ? Math.min((window.scrollY / max) * 100, 100) : 0;
      bar.style.width   = `${pct}%`;
      fill.style.width  = `${pct}%`;
      pctEl.textContent = `${Math.round(pct)}%`;
    }
    window.addEventListener('scroll', onScroll, { passive: true, signal });
    onScroll();

    const links = () => tocList.querySelectorAll<HTMLAnchorElement>('a');
    const obs = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          links().forEach((a) => {
            const active = a.getAttribute('href') === `#${e.target.id}`;
            a.style.color           = active ? 'var(--color-rust)' : 'var(--color-ink-faded)';
            a.style.fontWeight      = active ? '600' : (a.dataset.level === '2' ? '500' : '400');
            a.style.borderLeftColor = active ? 'var(--color-rust)' : 'transparent';
            a.style.background      = active ? 'rgba(139,58,42,0.07)' : '';
          });
        }
      },
      { rootMargin: '-10% 0% -60% 0%' }
    );
    headings.forEach((h) => obs.observe(h));
    signal.addEventListener('abort', () => obs.disconnect());

    // ── Citation tooltips ──────────────────────────────
    const tooltip = document.createElement('div');
    tooltip.className = 'cite-tooltip';
    document.body.appendChild(tooltip);
    signal.addEventListener('abort', () => tooltip.remove());

    const refMap: Record<string, string> = {};
    document.querySelectorAll<HTMLElement>('.references p').forEach((p) => {
      const m = p.textContent?.match(/^\[(\d+)\]/);
      if (m) refMap[m[1]] = p.innerHTML;
    });

    document.querySelectorAll<HTMLElement>('.cite').forEach((el) => {
      el.addEventListener('mouseenter', () => {
        const nums = (el.textContent ?? '').replace(/[\[\]\s]/g, '').split(',').filter(Boolean);
        const html = nums.map(n => refMap[n]).filter(Boolean).join('<br>');
        if (!html) return;
        tooltip.innerHTML = html;
        tooltip.style.display = 'block';
        const rect = el.getBoundingClientRect();
        const top  = rect.bottom + window.scrollY + 6;
        const left = Math.min(rect.left + window.scrollX, window.innerWidth - tooltip.offsetWidth - 16);
        tooltip.style.top  = `${top}px`;
        tooltip.style.left = `${Math.max(8, left)}px`;
      }, { signal });
      el.addEventListener('mouseleave', () => { tooltip.style.display = 'none'; }, { signal });
    });
    window.addEventListener('scroll', () => { tooltip.style.display = 'none'; }, { passive: true, signal });
  });
</script>

<style>
  /* ── Top progress bar ─────────────────────────────── */
  #reading-bar {
    position: fixed;
    top: 0; left: 0;
    height: 3px; width: 0%;
    background: linear-gradient(90deg, var(--color-rust), var(--color-sepia));
    z-index: 200;
    transition: width 0.1s linear;
  }
  @media (min-width: 1060px) { #reading-bar { display: none; } }

  /* ── Outer flex wrapper ───────────────────────────── */
  .lab-wrapper {
    display: flex;
    align-items: stretch;
    min-height: calc(100vh - 52px);
    flex: 1;
  }

  /* ── Left nav sidebar ─────────────────────────────── */
  #nav-sidebar { display: none; }

  @media (min-width: 1060px) {
    #nav-sidebar {
      display: block;
      width: 280px;
      flex-shrink: 0;
      align-self: stretch;
      background: var(--bg-panel);
    }
  }

  .nav-sticky {
    position: sticky;
    top: 52px;
    max-height: calc(100vh - 52px);
    overflow-y: auto;
    padding: 1.25rem;
  }

  /* ── Lab content (article + TOC grid) ────────────── */
  .lab-content { flex: 1; min-width: 0; display: flex; flex-direction: column; }

  .article-page {
    flex: 1;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    max-width: 1160px;
    margin: 0 auto;
    padding: 3rem 2rem;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1060px) {
    .article-page { grid-template-columns: 1fr 240px; }
  }

  /* ── TOC Sidebar ──────────────────────────────────── */
  #toc-sidebar { display: none; }

  @media (min-width: 1060px) {
    #toc-sidebar {
      display: block;
      position: sticky;
      top: calc(52px + 2rem);
      max-height: calc(100vh - 52px - 4rem);
      overflow-y: auto;
    }
  }

  .toc-card {
    background: var(--bg-panel);
    border: 1px solid var(--color-sepia);
    border-radius: 4px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .progress-section { display: flex; flex-direction: column; gap: 0.45rem; }
  .progress-header { display: flex; justify-content: space-between; align-items: center; }

  .sidebar-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-faded);
    font-family: var(--font-display);
  }

  #progress-pct { font-size: 0.75rem; font-weight: 600; color: var(--color-rust); }

  .progress-track {
    height: 4px;
    background: rgba(196, 154, 108, 0.2);
    border-radius: 999px;
    overflow: hidden;
  }

  #progress-fill {
    height: 100%; width: 0%;
    background: linear-gradient(90deg, var(--color-rust), var(--color-sepia));
    border-radius: 999px;
    transition: width 0.15s;
  }

  .toc-section { display: flex; flex-direction: column; gap: 0.5rem; }
  #toc-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.05rem; }

  /* ── Article ──────────────────────────────────────── */
  main { min-width: 0; width: 100%; }
  .prose { width: 100%; }

  .article-header {
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-sepia);
  }

  .article-header h1 { font-size: 2.25rem; margin-bottom: 0.5rem; }

  .description { color: var(--color-ink-faded); font-size: 1.05rem; font-style: italic; margin-bottom: 1rem; }

  .meta { display: flex; align-items: center; gap: 1.5rem; font-size: 0.85rem; color: var(--color-ink-faded); }

  .tags { display: flex; gap: 0.5rem; list-style: none; padding: 0; margin: 0; }

  .tag { background: rgba(196, 154, 108, 0.2); padding: 0.15em 0.6em; border-radius: 999px; font-size: 0.8rem; color: var(--color-ink-faded); }
</style>

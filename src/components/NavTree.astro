---
interface Props {
  articles: { id: string; title: string; order?: number }[];
  dirs?: { path: string; order: number; title?: string }[];
  base: string;       // full URL base, no trailing slash (e.g. /ena-world/central-lab)
  currentId?: string;
  accent?: string;    // CSS value, e.g. 'var(--color-rust)'
  label?: string;     // optional header shown above the tree
}

const { articles, dirs = [], base, currentId, accent = 'var(--color-rust)', label } = Astro.props;

const dirMap = new Map(dirs.map(d => [d.path, { order: d.order, title: d.title }]));

type NavNode = { name: string; slug: string | null; title: string; order: number; children: NavNode[] };

function buildTree(arts: { id: string; title: string; order?: number }[]): NavNode[] {
  const root: NavNode[] = [];

  function insert(level: NavNode[], parts: string[], d: number, slug: string, t: string, order: number) {
    if (d === parts.length - 1) {
      level.push({ name: parts[d], slug, title: t, order, children: [] });
    } else {
      const dirPath = parts.slice(0, d + 1).join('/');
      let dir = level.find(n => n.name === parts[d] && n.slug === null);
      if (!dir) {
        const info = dirMap.get(dirPath);
        dir = { name: parts[d], slug: null, title: info?.title ?? '', order: info?.order ?? 999, children: [] };
        level.push(dir);
      }
      insert(dir.children, parts, d + 1, slug, t, order);
    }
  }

  for (const a of arts) insert(root, a.id.split('/'), 0, a.id, a.title, a.order ?? 999);

  function sortLevel(nodes: NavNode[]) {
    nodes.sort((a, b) => a.order - b.order || a.name.localeCompare(b.name));
    nodes.forEach(n => sortLevel(n.children));
  }
  sortLevel(root);

  return root;
}

function esc(s: string) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function fmt(s: string) { return s.replace(/-/g,' ').replace(/\b\w/g, c => c.toUpperCase()); }
function encPath(slug: string) { return slug.split('/').map(encodeURIComponent).join('/'); }

function renderTree(nodes: NavNode[], b: string, curId: string | undefined, depth = 0): string {
  if (!nodes.length) return '';
  const cls = depth === 0 ? 'nt-list' : 'nt-list nt-sub';
  let h = `<ul class="${cls}">`;
  for (const n of nodes) {
    if (n.slug !== null) {
      const active = n.slug === curId ? ' nt-active' : '';
      h += `<li><a href="${b}/${encPath(n.slug)}" class="nt-link${active}">${esc(n.title)}</a></li>`;
    } else {
      h += `<li><details open><summary class="nt-folder">${esc(n.title || fmt(n.name))}</summary>`;
      h += renderTree(n.children, b, curId, depth + 1);
      h += `</details></li>`;
    }
  }
  h += '</ul>';
  return h;
}

const html = renderTree(buildTree(articles), base, currentId);

---

<nav class="nt-root" style={`--nt-accent: ${accent}`}>
  {label && <p class="nt-label">{label}</p>}
  <div set:html={html}></div>
</nav>

<style>
  .nt-root { font-size: 0.82rem; }

  .nt-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-faded);
    font-family: var(--font-display);
    padding: 0 0.4rem 0.5rem;
    margin: 0 0 0.3rem;
    border-bottom: 1px solid var(--nt-sub-border, rgba(128,100,60,0.15));
  }

  .nt-root :global(.nt-list) {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nt-root :global(.nt-sub) {
    padding-left: 0.75rem;
    margin-top: 0.1rem;
    border-left: 1px solid var(--nt-sub-border, rgba(128,100,60,0.15));
    margin-left: 0.25rem;
  }
  .nt-root :global(details) { margin: 0.04rem 0; }
  .nt-root :global(details > summary) { list-style: none; }
  .nt-root :global(details > summary::-webkit-details-marker) { display: none; }

  .nt-root :global(.nt-folder) {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.22rem 0.4rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-ink-faded);
    cursor: pointer;
    border-radius: 0.25rem;
    user-select: none;
    transition: color 0.1s, background 0.1s;
  }
  .nt-root :global(.nt-folder:hover) {
    color: var(--color-ink);
    background: var(--nt-hover-bg, rgba(0,0,0,0.04));
  }
  .nt-root :global(.nt-folder::before) {
    content: '▶';
    font-size: 0.48rem;
    transition: transform 0.15s;
    flex-shrink: 0;
    opacity: 0.6;
  }
  .nt-root :global(details[open] > .nt-folder::before) { transform: rotate(90deg); }

  .nt-root :global(.nt-link) {
    display: block;
    padding: 0.22rem 0.4rem;
    color: var(--color-ink-faded);
    text-decoration: none;
    border-radius: 0.25rem;
    border-left: 2px solid transparent;
    line-height: 1.4;
    transition: color 0.1s, background 0.1s, border-color 0.1s;
  }
  .nt-root :global(.nt-link:hover) {
    color: var(--color-ink);
    background: var(--nt-hover-bg, rgba(0,0,0,0.04));
  }
  .nt-root :global(.nt-active) {
    color: var(--nt-accent);
    border-left-color: var(--nt-accent);
    font-weight: 600;
  }
</style>
